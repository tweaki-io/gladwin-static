<!DOCTYPE html><html lang="en"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopsy</title>
    <link rel="icon" href="logo_lite-7c8246.png" type="image/png">
    <style>
        :root {
            --primary-: #503CEB;
            --secondary-: #757575;
            --light-: #ffff;
            --secondary-dark-: #212121; 
        }
        * {
            padding: 0;
            margin: 0;
            font-family: sans-serif;
        }
        .main-container {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
        .main-container .app-header {
            padding: 16px 20px;
        }
        .main-container .app-header>img {
            height: 24px;
        }
        .main-container .container {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 1.3rem;
        }
        .container p:nth-child(2) {
            font-weight: 600;
            color: var(--secondary-dark-);
        }
        .container p:nth-child(3) {
            color: var(--secondary-);
            font-size: 14px;
            line-height: 20px;
        }
        .main-container .nav-button {
            background-color: var(--primary-);
            padding: 14px;
            width: 182px;
            color: var(--light-);
            box-sizing: border-box;
            border: none;
            font-size: 1rem;
            border-radius: 5px;
            text-align: center;
            text-decoration: none;
        } 
        .container img {
            width: 124px;
            height: 148px;
        }
    </style>
</head>
<body>
    <div class="main-container">
        <header class="app-header">
            <img src="86d52f8f-6b6b-4191-94c4-f17f2cc2d456.png" alt="Shopsy logo">
        </header>
        <div class="container">
            <img src="f99b041a-6bec-44e2-95fd-f57be3878d27.png" alt="Error message logo">
            <p>Oops!</p>
            <p>Looks like the page you are<br>looking for no longer exists.</p>
            <a class="nav-button" href="https://www.shopsy.in">Continue Shopping</a>
        </div>
    </div>
    <script>

    </script>

</body></html>